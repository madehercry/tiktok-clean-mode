<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_fab.xml
    ==========
    Semi-transparent dark circle for the floating trigger button.
    • Oval shape so it looks like a pill/FAB regardless of device DPI.
    • Very subtle white stroke so the button reads against dark TikTok backgrounds.
    • Ripple effect is handled separately via the selectableItemBackgroundBorderless
      attribute on the ImageButton when needed; this drawable covers the shape only.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <solid android:color="@color/fab_background" />

    <stroke
        android:width="1dp"
        android:color="@color/fab_stroke" />

</shape>
