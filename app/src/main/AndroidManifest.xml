<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        SYSTEM_ALERT_WINDOW — allows us to draw our floating trigger button
        over other apps (including TikTok). Must be granted by the user via
        Settings > Apps > Special app access > Appear on top.
    -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!--
        The BIND_ACCESSIBILITY_SERVICE permission is declared on the <service>
        tag below; no separate <uses-permission> is needed for it.
    -->

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TikTokCleanMode"
        tools:targetApi="31">

        <!-- ── Main entry-point activity ── -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            ── Accessibility Service ──
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            prevents any app other than the system from binding to this service.

            The meta-data block points to our XML config which declares:
              • which packages we listen to (TikTok variants)
              • that we can retrieve window content and perform gestures
        -->
        <service
            android:name=".TikTokCleanService"
            android:exported="true"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">

            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>

            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

    </application>

</manifest>
